# zcrypt backend — environment configuration
#
# Copy this file to .env and fill in your own values.
#   cp .env.example .env
#
# NEVER commit a real .env file. It is gitignored on purpose.
# Every contributor must supply their own credentials.

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (e.g. a Neon serverless database).
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# 32-byte hex key for envelope encryption of platform tokens at rest.
# Generate one with: openssl rand -hex 32
MASTER_KEY=replace-with-32-byte-hex-key

# JWT signing secret. If left empty the server auto-generates an ephemeral one
# (tokens will not survive a restart), so set a stable value in production.
# Generate one with: openssl rand -hex 32
ZCRYPT_JWT_SECRET=replace-me

# Frontend URL — used for email links and the post-OAuth redirect, and added
# to the CORS whitelist automatically. No trailing slash in production.
FRONTEND_URL=http://localhost:3000

# Public backend URL (e.g. https://api.zcrypt.app), no trailing slash.
# Required for OAuth: it builds the redirect_uri and must EXACTLY match what is
# registered with Google/GitHub. If unset it is derived per-request, which
# usually breaks OAuth.
BACKEND_URL=http://localhost:8080

# Comma-separated CORS whitelist. Defaults to localhost; FRONTEND_URL is added
# automatically.
ALLOWED_ORIGINS=http://localhost:3000

# ── OAuth (optional) ──────────────────────────────────────────────────────────
# A provider is enabled only when BOTH its client ID and secret are set.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (optional) ──────────────────────────────────────────────────────────
# Used for email verification and password reset via Resend.

RESEND_API_KEY=
RESEND_FROM=zcrypt <noreply@example.com>

# ── Server (optional) ─────────────────────────────────────────────────────────

# Server port (default: 8080). On some hosts (e.g. Railway) PORT is injected.
ZCRYPT_PORT=8080

# Set to "true" ONLY for local load testing — disables all rate limiting.
# NEVER enable this in production.
DEV_MODE=false
