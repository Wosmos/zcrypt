# zcrypt production download tests
# Copy this to .env.prodtest and fill in your values.
# These credentials are ONLY used by: go test -tags=prodtest ./cmd/

# Production backend URL (no trailing slash)
PRODTEST_API=https://your-backend.up.railway.app

# Test account credentials (use an account WITHOUT 2FA)
PRODTEST_EMAIL=your-email@example.com
PRODTEST_PASSWORD=your-password
