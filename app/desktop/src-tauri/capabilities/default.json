{
  "identifier": "default",
  "description": "Default capabilities for zcrypt desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$TEMP/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    "shell:default",
    "shell:allow-execute",
    "notification:default",
    "notification:allow-notify"
  ]
}
